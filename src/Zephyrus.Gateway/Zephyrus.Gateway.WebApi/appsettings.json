{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "JwtSettings": {
    "Issuer": "Zephyrus.Identity",
    "Audience": "Zephyrus",
    "AccessTokenExpirationMinutes": 15
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "catalog-categories": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/categories/{**catch-all}"
        }
      },
      "catalog-products": {
        "ClusterId": "catalog-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "supplier": {
        "ClusterId": "supplier-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/suppliers/{**catch-all}"
        }
      },
      "procurement-orders": {
        "ClusterId": "procurement-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "procurement-purchase-requests": {
        "ClusterId": "procurement-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/purchase-requests/{**catch-all}"
        }
      },
      "notification": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://zephyrus.identity:8080/"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://zephyrus.catalog:8080/"
          }
        }
      },
      "supplier-cluster": {
        "Destinations": {
          "supplier": {
            "Address": "http://zephyrus.supplier:8080/"
          }
        }
      },
      "procurement-cluster": {
        "Destinations": {
          "procurement": {
            "Address": "http://zephyrus.procurement:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "http://zephyrus.notification:8080/"
          }
        }
      }
    }
  }
}
