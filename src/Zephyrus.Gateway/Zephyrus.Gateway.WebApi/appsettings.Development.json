{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Zephyrus": "Debug",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5051"
        }
      }
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "supplier-cluster": {
        "Destinations": {
          "supplier": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "procurement-cluster": {
        "Destinations": {
          "procurement": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  }
}
