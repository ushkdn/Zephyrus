{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "JwtSettings": {
    "Issuer": "Zephyrus.Identity",
    "Audience": "Zephyrus",
    "AccessTokenExpirationMinutes": 15
  },
  "AuthSettings": {
    "PasswordResetCodeExpirationMinutes": 5,
    "RefreshTokenExpirationDays": 15
  },
  "EmailSettings": {
    "Port": 587,
    "UseSsl": false
  }
}
